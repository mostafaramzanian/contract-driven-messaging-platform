# Environment variables for docker-compose.test.yml
# Used by the migrate, messaging, and gateway services during
# integration testing. Do not use these credentials anywhere else.
#
# These are container-internal addresses (e.g. `rabbitmq`, `postgres` are
# Docker Compose service names, resolvable only inside
# showcase-test-network). The host-side test runner (Jest, running
# directly on the CI runner or a developer's shell, not inside a
# container) reaches the same services via 127.0.0.1 on the host-mapped
# ports defined in docker-compose.test.yml's `ports:` -- which are
# intentionally the same port numbers as below (5672, 5432), so there is
# one consistent port per service rather than a different one for the
# container-internal vs. host-side address. See the header comment in
# docker-compose.test.yml for the resulting tradeoff with the dev stack.

POSTGRES_USER=admin
POSTGRES_PASSWORD=test_password
POSTGRES_DB=showcase_test_db

DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=test_password
DB_NAME=showcase_test_db

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

LOG_LEVEL=info
NODE_ENV=test

# Enables EventLifecyclePublisher (libs/contracts/src/lifecycle) so
# integration tests can observe event emit/receive/validate/persist stages
# deterministically instead of polling the database. Test-only: never set
# in dev/production env files.
EVENT_LIFECYCLE_TRACING=true

ALLOWED_ORIGINS=*

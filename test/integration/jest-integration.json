{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../..",
  "testEnvironment": "node",
  "testRegex": "test/integration/.*\\.integration-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@app/common(.*)$": "<rootDir>/libs/common/src$1",
    "^@app/contracts(.*)$": "<rootDir>/libs/contracts/src$1"
  },
  "testTimeout": 30000
}

# ============================================
# Messaging Showcase - Environment Variables
# ============================================

# PostgreSQL Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=showcase_db

# Database Connection (for NestJS services)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=your_secure_password_here
DB_NAME=showcase_db

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@showcase-rabbitmq:5672

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_secure_password_here

# Logging Configuration
LOG_LEVEL=info
NODE_ENV=development

# CORS - comma-separated list of allowed origins in production
# Example: http://yourdomain.com,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:8080,http://showcase.local:8080

{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "histogram", "name": "Histogram", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "dashboards": [
    {
      "uid": "cdmp-system-overview",
      "title": "CDMP — System Overview",
      "description": "Throughput, success rate, error rate, and queue depth",
      "tags": ["contract-driven-messaging", "overview"],
      "timezone": "utc",
      "refresh": "10s",
      "time": { "from": "now-30m", "to": "now" },
      "panels": [
        {
          "id": 1, "type": "stat", "title": "Messages / sec",
          "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(messages_processed_total[1m])", "legendFormat": "msg/s" }],
          "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
          "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0 }] } } }
        },
        {
          "id": 2, "type": "stat", "title": "Publish Rate",
          "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(outbox_published_total{source=\"gateway\"}[1m])", "legendFormat": "publish/s" }],
          "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
        },
        {
          "id": 3, "type": "stat", "title": "Consume Rate",
          "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(messages_consumed_total[1m])", "legendFormat": "consume/s" }],
          "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
        },
        {
          "id": 4, "type": "stat", "title": "Success Rate",
          "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(messages_processed_total{status=\"success\"}[5m]) / rate(messages_processed_total[5m]) * 100", "legendFormat": "%" }],
          "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
          "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 99 }, { "color": "green", "value": 99.5 }] } } }
        },
        {
          "id": 5, "type": "stat", "title": "Error Rate",
          "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(messages_processed_total{status=\"error\"}[5m]) / rate(messages_processed_total[5m]) * 100", "legendFormat": "%" }],
          "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
          "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] } } }
        },
        {
          "id": 6, "type": "stat", "title": "Queue Depth (messaging.work)",
          "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rabbitmq_queue_messages{queue=\"messaging.work\"}", "legendFormat": "depth" }],
          "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }] } } }
        },
        {
          "id": 7, "type": "timeseries", "title": "Throughput — publish vs consume rate (msg/s)",
          "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
          "targets": [
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(outbox_published_total{source=\"gateway\"}[1m])", "legendFormat": "Publish rate" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(messages_consumed_total[1m])", "legendFormat": "Consume rate" }
          ],
          "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10, "lineWidth": 2 } } }
        },
        {
          "id": 8, "type": "timeseries", "title": "Success rate vs error rate (%)",
          "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
          "targets": [
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(messages_processed_total{status=\"success\"}[5m]) / rate(messages_processed_total[5m]) * 100", "legendFormat": "Success %" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(messages_processed_total{status=\"error\"}[5m]) / rate(messages_processed_total[5m]) * 100", "legendFormat": "Error %" }
          ],
          "fieldConfig": { "defaults": { "unit": "percent" } }
        },
        {
          "id": 9, "type": "timeseries", "title": "Queue depth — messaging.work (with alert threshold)",
          "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
          "targets": [
            { "datasource": "${DS_PROMETHEUS}", "expr": "rabbitmq_queue_messages{queue=\"messaging.work\"}", "legendFormat": "Queue depth" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "100", "legendFormat": "Alert threshold" }
          ],
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }] } } }
        }
      ]
    },
    {
      "uid": "cdmp-reliability",
      "title": "CDMP — Reliability",
      "description": "Retry activity, DLQ growth, idempotency, publisher confirm failures",
      "tags": ["contract-driven-messaging", "reliability"],
      "timezone": "utc",
      "refresh": "10s",
      "time": { "from": "now-30m", "to": "now" },
      "panels": [
        {
          "id": 1, "type": "stat", "title": "Retry Rate",
          "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(retry_count_total[1m])", "legendFormat": "retries/s" }]
        },
        {
          "id": 2, "type": "stat", "title": "Retry Exhaustions",
          "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(retry_exhausted_total[30m])", "legendFormat": "exhausted" }],
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
        },
        {
          "id": 3, "type": "stat", "title": "DLQ Total (window)",
          "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(dlq_messages_total[30m])", "legendFormat": "dlq events" }],
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
        },
        {
          "id": 4, "type": "stat", "title": "Duplicates Prevented",
          "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(idempotency_duplicates_prevented_total[30m])", "legendFormat": "duplicates" }],
          "fieldConfig": { "defaults": { "color": { "fixedColor": "green", "mode": "fixed" } } }
        },
        {
          "id": 5, "type": "stat", "title": "Publisher Confirm Failures",
          "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(publisher_confirm_failures_total[30m])", "legendFormat": "failures" }],
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
        },
        {
          "id": 6, "type": "stat", "title": "Relay Failures (fenced)",
          "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(outbox_fenced_publishes_total[30m])", "legendFormat": "fenced" }],
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
        },
        {
          "id": 7, "type": "barchart", "title": "Retry count by attempt number",
          "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
          "targets": [
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(retry_count_total{attempt=\"1\"}[1m])", "legendFormat": "Attempt 1" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(retry_count_total{attempt=\"2\"}[1m])", "legendFormat": "Attempt 2" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(retry_count_total{attempt=\"3\"}[1m])", "legendFormat": "Attempt 3" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(retry_count_total{attempt=\"4\"}[1m])", "legendFormat": "Attempt 4" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(retry_count_total{attempt=\"5\"}[1m])", "legendFormat": "Attempt 5 (exhaust)" }
          ]
        },
        {
          "id": 8, "type": "timeseries", "title": "DLQ growth — increase(dlq_messages_total[15m])",
          "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(dlq_messages_total[15m])", "legendFormat": "DLQ events" }],
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "custom": { "fillOpacity": 20 } } }
        },
        {
          "id": 9, "type": "timeseries", "title": "Idempotency duplicates prevented vs redeliveries",
          "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
          "targets": [
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(idempotency_duplicates_prevented_total[1m])", "legendFormat": "Duplicates caught" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(messages_redelivered_total[1m])", "legendFormat": "Redelivery events" }
          ]
        }
      ]
    },
    {
      "uid": "cdmp-outbox-health",
      "title": "CDMP — Outbox Health",
      "description": "Pending events, relay latency, lock contention, stale-lock reaper",
      "tags": ["contract-driven-messaging", "outbox"],
      "timezone": "utc",
      "refresh": "10s",
      "time": { "from": "now-30m", "to": "now" },
      "panels": [
        {
          "id": 1, "type": "stat", "title": "Pending Events (Gateway outbox)",
          "gridPos": { "x": 0, "y": 0, "w": 5, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "outbox_pending_events{source=\"gateway\"}", "legendFormat": "pending" }],
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] } } }
        },
        {
          "id": 2, "type": "stat", "title": "Pending Events (Consumer outbox)",
          "gridPos": { "x": 5, "y": 0, "w": 5, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "outbox_pending_events{source=\"consumer\"}", "legendFormat": "pending" }],
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] } } }
        },
        {
          "id": 3, "type": "stat", "title": "Published Events (window)",
          "gridPos": { "x": 10, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(outbox_published_total[30m])", "legendFormat": "published" }]
        },
        {
          "id": 4, "type": "stat", "title": "Lock Contentions",
          "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(outbox_fenced_publishes_total[30m])", "legendFormat": "contentions" }],
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } } }
        },
        {
          "id": 5, "type": "stat", "title": "Relay Throughput",
          "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(outbox_published_total[1m])", "legendFormat": "relay/s" }],
          "fieldConfig": { "defaults": { "unit": "reqps" } }
        },
        {
          "id": 6, "type": "timeseries", "title": "Pending outbox events — gateway + consumer",
          "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
          "targets": [
            { "datasource": "${DS_PROMETHEUS}", "expr": "outbox_pending_events{source=\"gateway\"}", "legendFormat": "Gateway outbox" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "outbox_pending_events{source=\"consumer\"}", "legendFormat": "Consumer outbox" }
          ]
        },
        {
          "id": 7, "type": "timeseries", "title": "Published events — rate(outbox_published_total[1m])",
          "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(outbox_published_total[1m])*60", "legendFormat": "Published / min" }]
        },
        {
          "id": 8, "type": "timeseries", "title": "Relay latency percentiles — outbox_relay_latency_ms",
          "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
          "targets": [
            { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, rate(outbox_relay_latency_ms_bucket[1m]))", "legendFormat": "p50" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.95, rate(outbox_relay_latency_ms_bucket[1m]))", "legendFormat": "p95" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.99, rate(outbox_relay_latency_ms_bucket[1m]))", "legendFormat": "p99" }
          ],
          "fieldConfig": { "defaults": { "unit": "ms" } }
        },
        {
          "id": 9, "type": "histogram", "title": "Relay latency distribution — bucket histogram",
          "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(outbox_relay_latency_ms_bucket[5m])", "legendFormat": "{{le}}ms" }]
        },
        {
          "id": 10, "type": "timeseries", "title": "Lock contention — outbox_fenced_publishes_total",
          "gridPos": { "x": 0, "y": 20, "w": 8, "h": 6 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(outbox_fenced_publishes_total[1m])", "legendFormat": "Fenced publishes" }]
        },
        {
          "id": 11, "type": "timeseries", "title": "SKIP LOCKED claims per relay cycle",
          "gridPos": { "x": 8, "y": 20, "w": 8, "h": 6 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "outbox_relay_claims_per_cycle", "legendFormat": "Claims / cycle" }]
        },
        {
          "id": 12, "type": "timeseries", "title": "Stale-lock reaper — rows reclaimed",
          "gridPos": { "x": 16, "y": 20, "w": 8, "h": 6 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(outbox_reaper_reclaimed_total[1m])", "legendFormat": "Rows reclaimed" }]
        }
      ]
    },
    {
      "uid": "cdmp-distributed-tracing",
      "title": "CDMP — Distributed Tracing",
      "description": "Trace volume, E2E latency, top slow operations, trace error rate",
      "tags": ["contract-driven-messaging", "tracing", "opentelemetry"],
      "timezone": "utc",
      "refresh": "10s",
      "time": { "from": "now-30m", "to": "now" },
      "panels": [
        {
          "id": 1, "type": "stat", "title": "Trace Volume",
          "gridPos": { "x": 0, "y": 0, "w": 5, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(traces_total[30m])", "legendFormat": "traces" }]
        },
        {
          "id": 2, "type": "stat", "title": "E2E p50 Latency",
          "gridPos": { "x": 5, "y": 0, "w": 5, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, rate(e2e_request_duration_ms_bucket[5m]))", "legendFormat": "p50" }],
          "fieldConfig": { "defaults": { "unit": "ms" } }
        },
        {
          "id": 3, "type": "stat", "title": "E2E p99 Latency",
          "gridPos": { "x": 10, "y": 0, "w": 4, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.99, rate(e2e_request_duration_ms_bucket[5m]))", "legendFormat": "p99" }],
          "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 3000 }] } } }
        },
        {
          "id": 4, "type": "stat", "title": "Trace Error Rate",
          "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(traces_errors_total[5m]) / rate(traces_total[5m]) * 100", "legendFormat": "%" }],
          "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] } } }
        },
        {
          "id": 5, "type": "stat", "title": "Root Span Orphans",
          "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(trace_orphaned_root_spans_total[30m])", "legendFormat": "orphans" }],
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
        },
        {
          "id": 6, "type": "timeseries", "title": "Trace volume by service — spans/min",
          "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
          "targets": [
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(spans_total{service=\"gateway\"}[1m])*60", "legendFormat": "Gateway" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(spans_total{service=\"relay\"}[1m])*60", "legendFormat": "Relay" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(spans_total{service=\"consumer\"}[1m])*60", "legendFormat": "Consumer" }
          ]
        },
        {
          "id": 7, "type": "timeseries", "title": "End-to-end request duration percentiles (ms)",
          "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
          "targets": [
            { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, rate(e2e_request_duration_ms_bucket[1m]))", "legendFormat": "p50" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.95, rate(e2e_request_duration_ms_bucket[1m]))", "legendFormat": "p95" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.99, rate(e2e_request_duration_ms_bucket[1m]))", "legendFormat": "p99" }
          ],
          "fieldConfig": { "defaults": { "unit": "ms" } }
        },
        {
          "id": 8, "type": "timeseries", "title": "Trace error rate by service (%)",
          "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
          "targets": [
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(spans_errors_total{service=\"gateway\"}[5m]) / rate(spans_total{service=\"gateway\"}[5m]) * 100", "legendFormat": "Gateway" },
            { "datasource": "${DS_PROMETHEUS}", "expr": "rate(spans_errors_total{service=\"consumer\"}[5m]) / rate(spans_total{service=\"consumer\"}[5m]) * 100", "legendFormat": "Consumer" }
          ],
          "fieldConfig": { "defaults": { "unit": "percent" } }
        },
        {
          "id": 9, "type": "table", "title": "Top slow operations — p99 span duration",
          "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
          "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "topk(10, histogram_quantile(0.99, rate(span_duration_ms_bucket[5m])))", "legendFormat": "{{operation}}", "format": "table", "instant": true }],
          "fieldConfig": { "defaults": { "unit": "ms" } }
        }
      ]
    }
  ]
}

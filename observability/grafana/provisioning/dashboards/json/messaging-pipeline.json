{
  "title": "Messaging Pipeline Observability",
  "uid": "messaging-pipeline-obs",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "10s",
  "tags": ["messaging", "rabbitmq", "postgres", "otel"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "query": "label_values(messages_processed_total, service)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Messages Processed Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(messages_processed_total{service=~\"$service\"}[5m])) by (service, outcome)",
          "legendFormat": "{{service}} - {{outcome}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 2,
      "title": "Messages Failed Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(messages_failed_total{service=~\"$service\"}[5m])) by (service, error_class)",
          "legendFormat": "{{service}} - {{error_class}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 3,
      "title": "DLQ Messages (rate)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(dlq_messages_total{service=~\"$service\"}[5m])) by (service, error_class)",
          "legendFormat": "{{service}} - {{error_class}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Retry Count (rate, by attempt)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(retry_count_total{service=~\"$service\"}[5m])) by (service, attempt)",
          "legendFormat": "{{service}} attempt={{attempt}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 5,
      "title": "Outbox Pending Events",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "outbox_pending_events{service=~\"$service\"}",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Processing Duration p50/p95/p99",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(processing_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le, service, event_type))",
          "legendFormat": "p50 {{service}}/{{event_type}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(processing_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le, service, event_type))",
          "legendFormat": "p95 {{service}}/{{event_type}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(processing_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le, service, event_type))",
          "legendFormat": "p99 {{service}}/{{event_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 7,
      "title": "HTTP Request Duration (Gateway, p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"gateway\"}[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 8,
      "title": "Failure Ratio (Stat)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(messages_failed_total{service=~\"$service\"}[5m])) / clamp_min(sum(rate(messages_processed_total{service=~\"$service\"}[5m])) + sum(rate(messages_failed_total{service=~\"$service\"}[5m])), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Total DLQ (24h)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "sum(increase(dlq_messages_total{service=~\"$service\"}[24h]))" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "Messages Processed (24h total)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "sum(increase(messages_processed_total{service=~\"$service\"}[24h]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 11,
      "title": "Process Resident Memory",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "process_process_resident_memory_bytes{service=~\"$service\"}",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    }
  ]
}
